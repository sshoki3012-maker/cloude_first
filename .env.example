# Turso 接続情報 (https://turso.tech で取得)
TURSO_DATABASE_URL=libsql://your-db-name-yourname.turso.io
TURSO_AUTH_TOKEN=eyJhbGciOi...

# アプリへのログインパスワード (同窓会幹事で共有)
APP_PASSWORD=change-me-to-strong-password

# Cookie 署名用のランダム文字列 (32文字以上推奨)
# 例: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=please-replace-with-random-hex-at-least-32-chars

# 任意: ポート (デフォルト 3000)
PORT=3000
